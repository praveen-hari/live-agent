# Copy to .env and fill in your values

# ── LLM Providers (at least one required) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Tools ───────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Channels ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ── Gateway ─────────────────────────────────────────────────────────────────
GATEWAY_SECRET=change-me

# ── Agent ────────────────────────────────────────────────────────────────────
# Override the model from config.toml
# AGENT_MODEL=anthropic:claude-sonnet-4-5-20250929

# ── Observability ────────────────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=live-agent

# ── Config path (optional) ───────────────────────────────────────────────────
# LIVE_AGENT_CONFIG_PATH=/path/to/config.toml
